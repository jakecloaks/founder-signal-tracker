# API server (port 3001) — run `npm run dev` for full stack
PORT=3001

# Google Places API (Text Search) — enables live local business search
# https://console.cloud.google.com/ — enable Places API (New)
GOOGLE_PLACES_API_KEY=

# Optional: enterprise company analysis
NEWS_API_KEY=
OPENROUTER_API_KEY=
# OPENAI_API_KEY=

# Supabase (optional)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
